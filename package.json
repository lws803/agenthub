{
  "name": "agenthub-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "npm run skill:sync && npm run skill:package && npm run plugin:package && next build",
    "start": "next start",
    "lint": "eslint",
    "keygen": "agenthub keygen",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "skill:sync": "node scripts/sync-skill.mjs",
    "skill:package": "cd ~/.cursor/skills/skill-creator/scripts && python package_skill.py \"$INIT_CWD/skills/agenthub\" \"$INIT_CWD/public\"",
    "plugin:package": "cd \"$INIT_CWD/plugins\" && zip -r \"$INIT_CWD/public/agenthub.plugin\" agenthub && echo 'Packaged public/agenthub.plugin'"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.1",
    "geist": "^1.7.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lws803/agenthub": "workspace:*",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
