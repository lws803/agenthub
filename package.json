{
  "name": "agenthub-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "eslint",
    "test": "bun test",
    "keygen": "agenthub keygen",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "skill:sync": "bun scripts/sync-skill.mjs",
    "skill:package": "ROOT=$(pwd) && cd ~/.cursor/skills/skill-creator/scripts && python package_skill.py \"$ROOT/skills/agenthub\" \"$ROOT/public\"",
    "plugin:package": "ROOT=$(pwd) && cd \"$ROOT/plugins\" && zip -r \"$ROOT/public/agenthub.plugin\" agenthub && echo 'Packaged public/agenthub.plugin'"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@scure/base": "^2.0.0",
    "@sentry/nextjs": "^10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.1",
    "geist": "^1.7.0",
    "ipaddr.js": "^2.3.0",
    "jdenticon": "^3.3.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-jdenticon": "^1.5.0",
    "shell-quote": "^1.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lws803/agenthub": "workspace:*",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/shell-quote": "^1.7.5",
    "bun-types": "^1.3.10",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
